# ==============================================================================
# MINERVA - Configuración de PRODUCCIÓN
# ==============================================================================
# IMPORTANTE: Este archivo es una PLANTILLA. Cópialo como .env antes de desplegar.
# Genera nuevas contraseñas seguras para producción.
#
# MODOS DE DESPLIEGUE:
#   Monolítico: Front + Back + IA en el mismo servidor (todos los profiles)
#   Distribuido: Servicios en servidores separados (profiles individuales)
#
# En modo distribuido, ajusta las URLs de la sección "CONECTIVIDAD"
# para que apunten a las IPs/puertos reales de cada servidor.
# ==============================================================================

# --- GENERAL ---
COMPOSE_PROJECT_NAME=minerva

# --- GATEWAY (Puerto único de acceso externo) ---
GATEWAY_PORT=9122

# --- FRONTEND (Angular 17) ---
FRONTEND_PORT=80

# --- BACKEND LARAVEL ---
APP_NAME=MinervaBackend
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# ⚠️ Cambiar por la IP/dominio real del servidor
APP_URL=http://TU_IP_SERVIDOR:9122
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Puertos (no expuestos externamente en producción, gateway los enruta)
LARAVEL_PORT=80
DB_EXTERNAL_PORT=3306

# Credenciales Base de Datos (MariaDB)
# ⚠️ OBLIGATORIO: Cambiar antes de desplegar
DB_CONNECTION=mysql
DB_HOST=minerva-db
DB_PORT=3306
DB_DATABASE=minerva_production
DB_USERNAME=minerva_prod
DB_PASSWORD=CAMBIAR_CONTRASEÑA_SEGURA_AQUI
DB_ROOT_PASSWORD=CAMBIAR_ROOT_PASSWORD_AQUI

# Sesiones y Colas
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=database

# Redis
REDIS_HOST=minerva-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

# Docker
WWWUSER=minerva
WWWUSER_ID=1000

# ==============================================================================
# CONECTIVIDAD ENTRE SERVICIOS (SECCIÓN CRÍTICA)
# ==============================================================================
# Estas URLs definen cómo se comunican Backend, IA y Frontend entre sí.
#
# MONOLÍTICO (todo en el mismo servidor):
#   Todos los contenedores comparten red Docker → usar nombres internos.
#   IA_UPLOAD_URL=http://minerva-asr:8000
#   LARAVEL_URL=http://minerva-nginx:80
#   URL_DIARIZADOR=http://minerva-diarizador:8000
#
# DISTRIBUIDO (servicios en servidores separados):
#   Los servicios se comunican por IP:puerto expuesto.
#   IA_UPLOAD_URL=http://IP_SERVIDOR_IA:8002
#   LARAVEL_URL=http://IP_SERVIDOR_WEB:9122
#   URL_DIARIZADOR=http://minerva-diarizador:8000  (siempre interno al profile ia)
# ==============================================================================

# URL del servicio IA vista desde el Backend (Laravel → IA)
# Monolítico: http://minerva-asr:8000 (red Docker interna)
# Distribuido: http://IP_SERVIDOR_IA:8002 (puerto expuesto)
IA_UPLOAD_URL=http://minerva-asr:8000

# URL de Laravel vista desde la IA (IA → Laravel para callbacks)
# Monolítico: http://minerva-nginx:80 (red Docker interna)
# Distribuido: http://IP_SERVIDOR_WEB:9122 (gateway externo)
LARAVEL_URL=http://minerva-nginx:80

# URL del Diarizador vista desde el ASR (siempre interno al profile ia)
URL_DIARIZADOR=http://minerva-diarizador:8000

# Secret para autenticar callbacks IA→Laravel
# ⚠️ OBLIGATORIO: Generar con: openssl rand -base64 32
IA_CALLBACK_SECRET=CAMBIAR_GENERAR_CON_OPENSSL_RAND_BASE64_32

# Timeout para procesamiento de audio (segundos)
AI_TIMEOUT=7200

# ==============================================================================
# IA - Modelos y GPU
# ==============================================================================
# GPU_MODE: compact (8GB VRAM, modelo 0.6B) | full (16GB+ VRAM, modelo 1.7B)
GPU_MODE=full
MODELO_ASR=Qwen/Qwen3-ASR-1.7B
MODELO_ALIGNER=Qwen/Qwen3-ForcedAligner-0.6B
DISPOSITIVO_ASR=cuda:0
SENKO_DEVICE=cuda
SENKO_VAD=pyannote
SENKO_CLUSTERING=auto
ID_GPU=0
IA_ASR_PORT=8002

# ==============================================================================
# CORS y Autenticación SPA
# ==============================================================================
# ⚠️ Cambiar por la IP/dominio real del servidor
CORS_ALLOWED_ORIGINS=http://TU_IP_SERVIDOR:9122
SANCTUM_STATEFUL_DOMAINS=TU_IP_SERVIDOR:9122,TU_IP_SERVIDOR

# ==============================================================================
# NGINX GATEWAY (enrutamiento)
# ==============================================================================
# Upstreams internos (monolítico, mismo servidor)
FRONTEND_UPSTREAM=http://minerva-frontend:80
BACKEND_UPSTREAM=http://minerva-nginx:80

# ==============================================================================
# ALMACENAMIENTO
# ==============================================================================
AUDIO_MAX_SIZE_MB=2048
UPLOAD_TIMEOUT_HOURS=2
WORKER_REPLICAS=2
SSE_HEARTBEAT_SECONDS=30
SHARED_DIR_ENTRADA=./Shared/entrada
SHARED_DIR_SALIDA=./Shared/salida
RUTA_CONTENEDOR_ENTRADA=/app/compartido/entrada
RUTA_CONTENEDOR_SALIDA=/app/compartido/salida
