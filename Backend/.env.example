# ==============================================================================
# MINERVA BACKEND - Configuración de Entorno
# ==============================================================================

APP_NAME=MinervaBackend
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de Datos
DB_CONNECTION=mysql
DB_HOST=minerva-db
DB_PORT=3306
DB_DATABASE=backend_minerva
DB_USERNAME=minerva
DB_PASSWORD=minerva_secret

# Sesiones y Colas
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail
MAIL_MAILER=log

# ============================================
# ARQUITECTURA "PATATA CALIENTE" - Upload Streaming + SSE
# ============================================

# URL de IA para proxy streaming
IA_UPLOAD_URL=http://minerva-asr:8000

# Secret para callbacks de IA (¡cambiar en producción!)
IA_CALLBACK_SECRET=cambia_esto_en_produccion

# URL de Laravel vista desde IA
LARAVEL_URL=http://laravel-app:80

# Límites de upload
AUDIO_MAX_SIZE_MB=2048

# Timeout para peticiones IA (segundos)
AI_TIMEOUT=7200

# ============================================
# CONFIGURACIÓN LEGACY (compatibilidad)
# ============================================
AI_BACKEND_URL=http://minerva-asr:8000
AI_SERVICE_URL=http://minerva-asr:8000
AI_INPUT_PATH=/app/compartido/entrada
