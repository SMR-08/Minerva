# ==============================================================================
# MINERVA BACKEND - Configuración de Entorno
# ==============================================================================

APP_NAME=MinervaBackend
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de Datos
DB_CONNECTION=mysql
DB_HOST=minerva-db
DB_PORT=3306
DB_DATABASE=backend_minerva
DB_USERNAME=minerva
DB_PASSWORD=minerva_secret

# Sesiones y Colas
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=database

# Redis (Broker de colas)
REDIS_HOST=minerva-redis
REDIS_PASSWORD=***
REDIS_PORT=6379

# IMPORTANTE: Dejar vacío para que la cola IA (minerva_tasks) funcione sin prefijo.
# Si se omite, Laravel antepone "{APP_NAME}-database-" a todas las keys Redis
# y la IA (Python) no encontrará las tareas.
REDIS_PREFIX=

# Mail
MAIL_MAILER=log

# ============================================
# CONFIGURACION DE IA (UNIFICADA — config/audio.php)
# ============================================
# Todas las variables relacionadas con IA se centralizan en config('audio.ia.*')
# Ver config/audio.php para los defaults y claves completas.

# URL del microservicio ASR para upload streaming
IA_UPLOAD_URL=http://minerva-asr:8000

# URL de Laravel vista desde la IA (para callbacks)
LARAVEL_URL=http://minerva-nginx:80

# Secret compartido para autenticar callbacks de IA (cambiar en produccion!)
IA_CALLBACK_SECRET=cambiar_por_secret_generado_con_openssl_rand_base64_32

# Timeout maximo para peticiones a IA (segundos)
AI_TIMEOUT=7200

# Ruta de entrada para archivos de audio (modo legacy/admin)
AI_INPUT_PATH=/app/compartido/entrada

# ============================================
# ARQUITECTURA "PATATA CALIENTE" - Upload Streaming + SSE
# ============================================

# Limite maximo de upload (MB)
AUDIO_MAX_SIZE_MB=2048

# Intervalo de sondeo SSE (microsegundos)
SSE_POLL_INTERVAL_MICROSECONDS=2000000

# ============================================
# SANCTUM (Tokens API)
# ============================================

# Expiracion de tokens Sanctum en minutos (null = no expiran)
# Por defecto 43200 (30 dias). Usar null para tokens sin expiracion.
# SANCTUM_TOKEN_EXPIRATION=43200

# ============================================
# CONFIGURACION LEGACY (compatibilidad)
# AI_BACKEND_URL y AI_SERVICE_URL ya no se usan en PHP (ver config/audio.php)
# ============================================
# AI_BACKEND_URL=http://minerva-asr:8000
# AI_SERVICE_URL=http://minerva-asr:8000
AI_INPUT_PATH=/app/compartido/entrada
