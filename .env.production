# ==============================================================================
# MINERVA - Configuración de PRODUCCIÓN
# ==============================================================================
# IMPORTANTE: Este archivo es una PLANTILLA. Cópialo como .env antes de desplegar.
# Genera nuevas contraseñas seguras para producción.
# ==============================================================================

# --- GENERAL ---
COMPOSE_PROJECT_NAME=minerva

# --- GATEWAY (Puerto único de acceso) ---
GATEWAY_PORT=9122

# --- FRONTEND (Angular 17) ---
# Puerto interno, no expuesto al host
FRONTEND_PORT=80

# --- BACKEND LARAVEL ---
APP_NAME=MinervaBackend
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://150.214.56.73:9122
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Puertos internos (no expuestos al host)
LARAVEL_PORT=80
DB_EXTERNAL_PORT=3306

# Credenciales Base de Datos (MariaDB)
# ⚠️ CAMBIAR ESTAS CONTRASEÑAS EN PRODUCCIÓN
DB_CONNECTION=mysql
DB_HOST=minerva-db
DB_PORT=3306
DB_DATABASE=minerva_production
DB_USERNAME=minerva_prod
DB_PASSWORD=CAMBIAR_CONTRASEÑA_SEGURA_AQUI
DB_ROOT_PASSWORD=CAMBIAR_ROOT_PASSWORD_AQUI

# Sesiones y Colas
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail (Desactivado por defecto)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

# Docker - Usuario del contenedor PHP
WWWUSER=minerva
WWWUSER_ID=1000

# --- BACKEND IA (FastAPI + GPU) ---

# Modelos ASR
# Opciones: Qwen/Qwen3-ASR-0.6B (velocidad), Qwen/Qwen3-ASR-1.7B (calidad)
MODELO_ASR=Qwen/Qwen3-ASR-1.7B
MODELO_ALIGNER=Qwen/Qwen3-ForcedAligner-0.6B
# Dispositivo para el ASR (cuda:0, cuda:1, cpu)
DISPOSITIVO_ASR=cuda:0

# Diarizador (Senko)
# Dispositivo: auto, cuda, coreml, cpu
SENKO_DEVICE=cuda
# Modelo VAD: auto, pyannote, silero
SENKO_VAD=pyannote
# Clustering: auto, gpu, cpu
SENKO_CLUSTERING=auto

# GPU
ID_GPU=0

# Nombres de archivos de salida
NOMBRE_ARCHIVO_TRANSCRIPCION=transcripcion.txt
NOMBRE_ARCHIVO_CONVERSACION=conversacion.json

# --- COMUNICACIÓN ENTRE SERVICIOS (URLs internas Docker) ---
# URL del ASR vista desde Laravel
AI_BACKEND_URL=http://minerva-asr:8000
AI_SERVICE_URL=http://minerva-asr:8000
# URL del Diarizador vista desde el ASR
URL_DIARIZADOR=http://minerva-diarizador:8000
# Timeout para peticiones IA (segundos)
AI_TIMEOUT=300

# --- CARPETA COMPARTIDA (Negociación IA <-> Laravel) ---
# Rutas en el HOST (relativas a la raíz del proyecto Minerva)
SHARED_DIR_ENTRADA=./Shared/entrada
SHARED_DIR_SALIDA=./Shared/salida

# Rutas DENTRO de los contenedores (absolutas) - No modificar salvo necesidad
RUTA_CONTENEDOR_ENTRADA=/app/compartido/entrada
RUTA_CONTENEDOR_SALIDA=/app/compartido/salida

# --- CORS (Configuración de seguridad) ---
# IP del servidor para CORS
CORS_ALLOWED_ORIGINS=http://150.214.56.73:9122
