# ==============================================================================
# MINERVA - Archivo de Configuración Unificado
# Este archivo controla TODOS los servicios del proyecto.
# Cópialo como .env y personaliza los valores según tu entorno.
# ==============================================================================

# --- GENERAL ---
COMPOSE_PROJECT_NAME=minerva

# --- NGINX GATEWAY (solo producción, DEV=0) ---
GATEWAY_PORT=9122
FRONTEND_UPSTREAM=http://minerva-frontend:80
BACKEND_UPSTREAM=http://minerva-nginx:80

# --- FRONTEND (Angular 17) ---
FRONTEND_PORT=4200

# --- BACKEND LARAVEL ---
APP_NAME=MinervaBackend
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Debug granular por modulo (0=off, 1=on, solo desarrollo)
DEBUG_AUDIO=0
DEBUG_AUTH=0
DEBUG_IA=0
DEBUG_QUEUE=0
DEBUG_SSE=0
DEBUG_DB=0

# Puertos expuestos al host
LARAVEL_PORT=8001
DB_EXTERNAL_PORT=3307

# Credenciales Base de Datos (MariaDB)
DB_CONNECTION=mysql
DB_HOST=minerva-db
DB_PORT=3306
DB_DATABASE=backend_minerva
DB_USERNAME=minerva
DB_PASSWORD=minerva_secret
DB_ROOT_PASSWORD=root_secret

# Sesiones y Colas
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=database

# Redis (Broker de colas unificada)
REDIS_HOST=minerva-redis
REDIS_PASSWORD=minerva_dev_redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# Cola unificada
GPU_MODE=compact
GPU_CONCURRENCY=1
CPU_CONCURRENCY=2
AUTO_SUMMARY=true
SUMMARY_MODEL=Qwen/Qwen3.5-0.8B
SUMMARY_MAX_TOKENS=1024
SUMMARY_INPUT_MAX_TOKENS=32768
URL_RESUMIDOR=http://minerva-resumidor:8000

# Mail (Desactivado por defecto)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

# Docker - Usuario del contenedor PHP
WWWUSER=minerva
WWWUSER_ID=1000

# --- BACKEND IA (FastAPI + GPU) ---

# Modelos ASR
# Qwen3-ASR-0.6B (~2GB VRAM) para GPUs 8GB (compact)
# Qwen3-ASR-1.7B (~5.5GB VRAM) para GPUs 16GB+ (full)
# GPU_MODE: compact | full
GPU_MODE=compact
MODELO_ASR=Qwen/Qwen3-ASR-0.6B
MODELO_ALIGNER=Qwen/Qwen3-ForcedAligner-0.6B
# Dispositivo para el ASR (cuda:0, cuda:1, cpu)
DISPOSITIVO_ASR=cuda:0

# Diarizador (Senko)
# Dispositivo: auto, cuda, coreml, cpu
SENKO_DEVICE=cuda
# Modelo VAD: auto, pyannote, silero
SENKO_VAD=pyannote
# Clustering: auto, gpu, cpu
SENKO_CLUSTERING=auto

# Puertos IA expuestos al host
IA_ASR_PORT=8002

# GPU
ID_GPU=0

# Nombres de archivos de salida
NOMBRE_ARCHIVO_TRANSCRIPCION=transcripcion.txt
NOMBRE_ARCHIVO_CONVERSACION=conversacion.json

# --- COMUNICACIÓN ENTRE SERVICIOS (URLs internas Docker) ---
# URL del ASR vista desde Laravel (legacy, sin uso activo en PHP)
# AI_BACKEND_URL=http://minerva-asr:8000
# AI_SERVICE_URL=http://minerva-asr:8000
# URL del Diarizador vista desde el ASR
URL_DIARIZADOR=http://minerva-diarizador:8000
# Timeout para peticiones IA (segundos)
AI_TIMEOUT=7200

# --- CORS ---
# CORS_ORIGINS: usado por IA/main.py (FastAPI) para CORS del ASR
CORS_ORIGINS=*
# CORS_ALLOWED_ORIGINS: usado por cors.php de Laravel en APP_ENV=production
# En desarrollo (APP_ENV=local), cors.php permite todos (*)
CORS_ALLOWED_ORIGINS=http://localhost:4200
# SANCTUM_STATEFUL_DOMAINS: dominios SPA para autenticación Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:4200,localhost

# --- ARQUITECTURA "PATATA CALIENTE" (Upload Streaming + SSE) ---
# URL de upload para IA (usada por backend para proxy streaming)
IA_UPLOAD_URL=http://minerva-asr:8000
# Secret para callbacks de IA a Laravel
# Genera uno seguro con: openssl rand -base64 32
IA_CALLBACK_SECRET=cambiar_por_secret_generado_con_openssl_rand_base64_32
# URL de Laravel vista desde IA (para callbacks SSE)
# En produccion, la IP real se configura en .env (no en .example)
# Los defaults usan nombres Docker para desarrollo
LARAVEL_URL=http://minerva-nginx:80

# Límites de upload
AUDIO_MAX_SIZE_MB=2048
UPLOAD_TIMEOUT_HOURS=2

# Workers de procesamiento
WORKER_REPLICAS=2

# SSE (Server-Sent Events)
SSE_HEARTBEAT_SECONDS=30
SSE_POLL_INTERVAL_MICROSECONDS=2000000

# Sanctum (Tokens API)
# SANCTUM_TOKEN_EXPIRATION=43200

# --- CARPETA COMPARTIDA (Negociación IA <-> Laravel) ---
# NOTA: En arquitectura "Patata Caliente" esto NO se usa para archivos de audio
# Solo se mantiene para compatibilidad con versiones anteriores
# Rutas en el HOST (relativas a la raíz del proyecto Minerva)
SHARED_DIR_ENTRADA=./Shared/entrada
SHARED_DIR_SALIDA=./Shared/salida

# Rutas DENTRO de los contenedores (absolutas) - No modificar salvo necesidad
RUTA_CONTENEDOR_ENTRADA=/app/compartido/entrada
RUTA_CONTENEDOR_SALIDA=/app/compartido/salida
